# Which trained model to use by default.
# Resolves to models/<DEFAULT_MODEL>.pth + models/<DEFAULT_MODEL>.index
DEFAULT_MODEL=myvoice_v1

# Default Edge-TTS voice for stage 1.
# Run `python src/generate.py --list-voices` to see all English options.
DEFAULT_EDGE_VOICE=en-US-GuyNeural

# GPU device RVC will use
DEVICE=cuda:0
